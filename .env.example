# ─── API Keys ─────────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ElevenLabs Speech-to-Text (multi-key with automatic fallback)
# Use _01 / _02 for multiple keys, or legacy ELEVENLABS_API_KEY for single key.
ELEVENLABS_API_KEY_01=your_primary_elevenlabs_key_here
ELEVENLABS_API_KEY_02=your_fallback_elevenlabs_key_here
ELEVENLABS_API_KEY_03=your_tertiary_elevenlabs_key_here
# ELEVENLABS_API_KEY=your_single_key_here   ← legacy single-key format

# ─── DeepL (Translator Fallback) ────────────────────────────────────────────
# Used only when Gemini translation fails or is unavailable.
# Free tier keys end with ":fx".  Leave blank to disable the fallback —
# segments will then be returned with their source-language text.
DEEPL_API_KEY=

# ─── yt-dlp (Clip Finder) ───────────────────────────────────────────────────
# Path to yt-dlp binary. Default: ./bin/yt-dlp.exe
YTDLP_PATH=./bin/yt-dlp.exe

# ─── FFmpeg ───────────────────────────────────────────────────────────────────
# Leave blank to use system PATH, or set absolute path to ffmpeg binary
FFMPEG_PATH=
FFPROBE_PATH=

# ─── Pipeline Paths ───────────────────────────────────────────────────────────
OUTPUT_DIR=./output
TEMP_DIR=./output/temp

